@model ChatApp.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChatApp</title>
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
    <div class="auth-card">
        <h1>Đăng nhập</h1>
        <p class="auth-sub">Chào mừng bạn quay lại ChatApp</p>
        <form method="post" action="/Account/Login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <div asp-validation-summary="ModelOnly" class="validation"></div>
            <label>Email</label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="validation"></span>

            <label>Mật khẩu</label>
            <input asp-for="Password" />
            <span asp-validation-for="Password" class="validation"></span>

            <button type="submit">Đăng nhập</button>
        </form>
        <p class="auth-link">Chưa có tài khoản? <a href="/Account/Register">Đăng ký</a></p>
    </div>
</body>
</html>
